---
import SkyrimDivider from './SkyrimDivider.astro';
import {
	getLangFromUrl,
	useTranslations,
	localizePath,
} from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const year = new Date().getFullYear();

const items = [
	{ key: 'nav.home', path: '/' },
	{ key: 'nav.blog', path: '/blog' },
	{ key: 'nav.about', path: '/about' },
] as const;
---

<footer class="footer">
	<div class="container">
		<SkyrimDivider />

		<div class="footer__inner">
			<div class="footer__brand">
				<span class="footer__name">{t('site.title')}</span>
				<span class="footer__note">{t('footer.note')}</span>
			</div>

			<nav class="footer__nav" aria-label="Footer">
				<ul>
					{
						items.map((item) => (
							<li>
								<a href={localizePath(item.path, lang)}>{t(item.key)}</a>
							</li>
						))
					}
				</ul>
			</nav>
		</div>

		<p class="footer__legal">
			© {year} {t('site.title')}. {t('footer.rights')}
		</p>
	</div>
</footer>

<style>
	.footer {
		margin-top: clamp(3rem, 8vw, 6rem);
		border-top: 1px solid var(--hairline);
		padding-block: clamp(1.5rem, 4vw, 2.5rem) 2.5rem;
		background: linear-gradient(to top, rgba(16, 19, 22, 0.6), transparent);
	}

	.footer__inner {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 2rem;
		flex-wrap: wrap;
	}

	.footer__brand {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.footer__name {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 1rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--ink);
	}

	.footer__note {
		font-size: 0.85rem;
		color: var(--faint);
		font-style: italic;
	}

	.footer__nav ul {
		display: flex;
		flex-wrap: wrap;
		gap: clamp(1rem, 3vw, 2rem);
	}

	.footer__nav a {
		font-size: 0.74rem;
		font-weight: 600;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--muted);
		transition: color 0.25s var(--ease), text-shadow 0.25s var(--ease);
	}

	.footer__nav a:hover {
		color: var(--ice);
		text-shadow: 0 0 10px var(--glow-ice);
	}

	.footer__legal {
		margin-top: 2rem;
		font-size: 0.72rem;
		letter-spacing: 0.1em;
		color: var(--faint);
		text-align: center;
	}

	@media (max-width: 560px) {
		.footer__inner {
			justify-content: center;
			text-align: center;
		}

		.footer__brand {
			align-items: center;
		}
	}
</style>
