---
import SkyrimDivider from './SkyrimDivider.astro';
import type { Post } from '../data/posts';
import { getLangFromUrl, useTranslations, localizePath } from '../i18n/ui';

interface Props {
	post: Post;
}

const { post } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const content = post[lang];

const d = new Date(post.date);
const dateISO = d.toISOString();
const dateLabel = new Intl.DateTimeFormat(lang, {
	day: '2-digit',
	month: 'long',
	year: 'numeric',
}).format(d);
---

<article class="post">
	<header class="post__head">
		<time class="post__date" datetime={dateISO}>{dateLabel}</time>
		<h1 class="post__title">{content.title}</h1>
		<ul class="post__tags" aria-label="Tags">
			{post.tags.map((tag) => <li class="tag">{tag}</li>)}
		</ul>
	</header>

	<SkyrimDivider />

	<div class="post__body">
		<p class="post__lead">{content.description}</p>
		{content.body.map((para) => <p>{para}</p>)}
	</div>

	<footer class="post__foot">
		<a class="back" href={localizePath('/blog', lang)}>
			<span aria-hidden="true">←</span>
			{t('post.back')}
		</a>
	</footer>
</article>

<style>
	.post {
		max-width: 44rem;
		margin-inline: auto;
	}

	.post__head {
		text-align: center;
	}

	.post__date {
		font-size: 0.72rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--faint);
	}

	.post__title {
		margin-top: 0.75rem;
		font-size: clamp(1.9rem, 5vw, 2.8rem);
	}

	.post__tags {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.5rem;
		margin-top: 1.1rem;
	}

	.tag {
		font-size: 0.66rem;
		font-weight: 600;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--gold);
		padding: 0.28rem 0.6rem;
		border: 1px solid var(--gold-dim);
		border-radius: 2px;
		background: rgba(200, 168, 107, 0.06);
	}

	.post__body p {
		margin-bottom: 1.35rem;
		font-size: 1.05rem;
	}

	.post__lead {
		color: var(--ink);
		font-size: 1.2rem !important;
		line-height: 1.6;
	}

	.post__foot {
		margin-top: 3rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--hairline);
	}

	.back {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		font-size: 0.74rem;
		font-weight: 600;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--muted);
		transition: color 0.25s var(--ease), text-shadow 0.25s var(--ease);
	}

	.back:hover {
		color: var(--ice);
		text-shadow: 0 0 10px var(--glow-ice);
	}
</style>
