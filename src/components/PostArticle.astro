---
import SkyrimDivider from './SkyrimDivider.astro';
import Comments from './Comments.astro';
import { render } from 'astro:content';
import type { BlogEntry } from '../lib/blog';
import { getLangFromUrl, useTranslations, localizePath } from '../i18n/ui';

interface Props {
	entry: BlogEntry;
}

const { entry } = Astro.props;
const { title, description, tags, date } = entry.data;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { Content } = await render(entry);

const dateISO = date.toISOString();
const dateLabel = new Intl.DateTimeFormat(lang, {
	day: '2-digit',
	month: 'long',
	year: 'numeric',
}).format(date);
---

<article class="post">
	<header class="post__head">
		<time class="post__date" datetime={dateISO}>{dateLabel}</time>
		<h1 class="post__title">{title}</h1>
		<ul class="post__tags" aria-label="Tags">
			{tags.map((tag) => <li class="tag">{tag}</li>)}
		</ul>
	</header>

	<SkyrimDivider />

	<div class="post__body">
		<p class="post__lead">{description}</p>
		<Content />
	</div>

	<footer class="post__foot">
		<a class="back" href={localizePath('/blog', lang)}>
			<span aria-hidden="true">←</span>
			{t('post.back')}
		</a>
	</footer>
</article>

<div class="lightbox" data-lightbox hidden aria-hidden="true">
	<button
		class="lightbox__close"
		type="button"
		data-lightbox-close
		aria-label={lang === 'it' ? 'Chiudi' : 'Close'}
	>
		×
	</button>
	<img class="lightbox__img" data-lightbox-img src="" alt="" />
</div>

<Comments />

<style>
	.post {
		max-width: 44rem;
		margin-inline: auto;
	}

	.post__head {
		text-align: center;
	}

	.post__date {
		font-size: 0.72rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--faint);
	}

	.post__title {
		margin-top: 0.75rem;
		font-size: clamp(1.9rem, 5vw, 2.8rem);
	}

	.post__tags {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.5rem;
		margin-top: 1.1rem;
	}

	.tag {
		font-size: 0.66rem;
		font-weight: 600;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--gold);
		padding: 0.28rem 0.6rem;
		border: 1px solid var(--gold-dim);
		border-radius: 2px;
		background: rgba(200, 168, 107, 0.06);
	}

	.post__body :global(p) {
		margin-bottom: 1.35rem;
		font-size: 1.05rem;
	}

	.post__body :global(img) {
		display: block;
		width: auto;
		max-width: 100%;
		height: auto;
		margin: 1.75rem auto;
		border-radius: 4px;
		cursor: zoom-in;
		transition: filter 0.25s var(--ease);
	}

	.post__body :global(img:hover),
	.post__body :global(img:focus-visible) {
		filter: brightness(1.08);
		outline: none;
	}

	.post__body :global(ul),
	.post__body :global(ol) {
		margin: 0 0 1.35rem;
		padding-left: 1.6rem;
	}

	.post__body :global(ul) {
		list-style: disc;
	}

	.post__body :global(ol) {
		list-style: decimal;
	}

	.post__body :global(li) {
		margin-bottom: 0.5rem;
		font-size: 1.05rem;
		line-height: 1.65;
	}

	.post__body :global(li::marker) {
		color: var(--gold);
	}

	.post__lead {
		color: var(--ink);
		font-size: 1.2rem !important;
		line-height: 1.6;
	}

	.post__foot {
		margin-top: 3rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--hairline);
	}

	.back {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		font-size: 0.74rem;
		font-weight: 600;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--muted);
		transition: color 0.25s var(--ease), text-shadow 0.25s var(--ease);
	}

	.back:hover {
		color: var(--ice);
		text-shadow: 0 0 10px var(--glow-ice);
	}

	.lightbox {
		position: fixed;
		inset: 0;
		z-index: 100;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: clamp(1rem, 4vw, 3rem);
		background: rgba(8, 10, 14, 0.88);
		backdrop-filter: blur(4px);
		cursor: zoom-out;
		opacity: 0;
		transition: opacity 0.25s var(--ease);
	}

	.lightbox[hidden] {
		display: none;
	}

	.lightbox.is-open {
		opacity: 1;
	}

	.lightbox__img {
		max-width: 90vw;
		max-height: 90vh;
		width: auto;
		height: auto;
		border-radius: 4px;
		box-shadow: 0 24px 60px rgba(0, 0, 0, 0.6);
		cursor: default;
		transform: scale(0.97);
		transition: transform 0.25s var(--ease);
	}

	.lightbox.is-open .lightbox__img {
		transform: scale(1);
	}

	.lightbox__close {
		position: absolute;
		top: clamp(0.75rem, 2vw, 1.5rem);
		right: clamp(0.75rem, 2vw, 1.5rem);
		width: 2.75rem;
		height: 2.75rem;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 1.8rem;
		line-height: 1;
		color: var(--ink);
		background: transparent;
		border: 1px solid var(--hairline);
		border-radius: 2px;
		cursor: pointer;
		transition: color 0.25s var(--ease), border-color 0.25s var(--ease);
	}

	.lightbox__close:hover {
		color: var(--ice);
		border-color: var(--hairline-strong);
	}

	@media (prefers-reduced-motion: reduce) {
		.lightbox,
		.lightbox__img {
			transition: none;
		}
	}
</style>

<script>
	// Click a post image to view it full-size in an overlay.
	// Progressive enhancement: without JS the images are plain <img>.
	const lightbox = document.querySelector<HTMLElement>('[data-lightbox]');
	const lightboxImg =
		document.querySelector<HTMLImageElement>('[data-lightbox-img]');
	const closeBtn = document.querySelector<HTMLButtonElement>(
		'[data-lightbox-close]',
	);
	const images = document.querySelectorAll<HTMLImageElement>('.post__body img');

	if (lightbox && lightboxImg && closeBtn && images.length) {
		let lastFocused: HTMLElement | null = null;

		const open = (img: HTMLImageElement) => {
			lastFocused = document.activeElement as HTMLElement;
			lightboxImg.src = img.currentSrc || img.src;
			lightboxImg.alt = img.alt;
			lightbox.hidden = false;
			lightbox.setAttribute('aria-hidden', 'false');
			document.body.style.overflow = 'hidden';
			// Next frame so the fade-in transition runs from opacity 0.
			requestAnimationFrame(() => lightbox.classList.add('is-open'));
			closeBtn.focus();
		};

		const close = () => {
			lightbox.classList.remove('is-open');
			lightbox.setAttribute('aria-hidden', 'true');
			document.body.style.overflow = '';
			const finish = () => {
				lightbox.hidden = true;
				lightboxImg.src = '';
				lightbox.removeEventListener('transitionend', finish);
			};
			lightbox.addEventListener('transitionend', finish);
			lastFocused?.focus();
		};

		images.forEach((img) => {
			img.setAttribute('role', 'button');
			img.setAttribute('tabindex', '0');
			img.addEventListener('click', () => open(img));
			img.addEventListener('keydown', (e) => {
				if (e.key === 'Enter' || e.key === ' ') {
					e.preventDefault();
					open(img);
				}
			});
		});

		closeBtn.addEventListener('click', close);
		// Click on the backdrop (but not the image itself) closes.
		lightbox.addEventListener('click', (e) => {
			if (e.target !== lightboxImg) close();
		});
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && !lightbox.hidden) close();
		});
	}
</script>
