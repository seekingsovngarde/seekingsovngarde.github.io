---
import BaseLayout from '../layouts/BaseLayout.astro';
import SkyrimDivider from '../components/SkyrimDivider.astro';
import { getLangFromUrl, useTranslations } from '../i18n/ui';

const t = useTranslations(getLangFromUrl(Astro.url));

const disciplines = ['CODING', 'GDR', 'MINIATURE'];
---

<BaseLayout title={t('about.title')} description={t('about.intro')}>
	<section class="page-head">
		<h1>{t('about.title')}</h1>
		<p class="page-head__intro">{t('about.intro')}</p>
	</section>

	<SkyrimDivider />

	<article class="prose">
		<p>
			Salve, viandante. Sono uno sviluppatore di giorno e cacciatore di
			draghi nelle ore piccole. <strong>Seeking Sovngarde</strong> è il
			diario dove annoto ciò che imparo lungo la strada: architetture di
			codice eleganti, sessioni di gioco di ruolo che diventano storie, e
			miniature che prendono vita un velo di colore alla volta.
		</p>
		<p>
			Credo che le tre cose abbiano più in comune di quanto sembri: tutte
			premiano la pazienza, l'attenzione ai dettagli e il coraggio di
			ricominciare quando qualcosa non convince. Qui condivido sia i
			successi sia gli errori — perché anche un fallimento critico è pur
			sempre un tiro di dado.
		</p>

		<h2>Discipline</h2>
		<ul class="disciplines" aria-label="Discipline">
			{disciplines.map((d) => <li class="tag">{d}</li>)}
		</ul>

		<h2>Dove trovarmi</h2>
		<p>
			Trovi i miei esperimenti su
			<a class="link" href="https://github.com" rel="me noopener">GitHub</a>.
			Per due chiacchiere su codice, dadi o pennelli, le porte della
			Taverna sono sempre aperte.
		</p>
	</article>
</BaseLayout>

<style>
	.page-head {
		text-align: center;
		max-width: 46rem;
		margin-inline: auto;
	}

	.page-head__intro {
		margin-top: 1rem;
		font-size: clamp(1rem, 2.5vw, 1.15rem);
		color: var(--muted);
	}

	.prose {
		max-width: 44rem;
		margin-inline: auto;
	}

	.prose p {
		margin-bottom: 1.25rem;
		font-size: 1.02rem;
	}

	.prose strong {
		color: var(--ink);
		font-weight: 600;
	}

	.prose h2 {
		font-size: 1.4rem;
		margin-top: 2.5rem;
		margin-bottom: 1rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.disciplines {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.tag {
		font-size: 0.66rem;
		font-weight: 600;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--gold);
		padding: 0.28rem 0.6rem;
		border: 1px solid var(--gold-dim);
		border-radius: 2px;
		background: rgba(200, 168, 107, 0.06);
	}

	.link {
		color: var(--gold);
		border-bottom: 1px solid var(--gold-dim);
		transition: text-shadow 0.25s var(--ease);
	}

	.link:hover {
		text-shadow: 0 0 10px var(--gold-dim);
	}
</style>
