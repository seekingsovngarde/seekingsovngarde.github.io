---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SkyrimDivider from '../../components/SkyrimDivider.astro';
import PostCard from '../../components/PostCard.astro';
import { posts, toCardProps } from '../../data/posts';
import { getLangFromUrl } from '../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const latest = posts.slice(0, 3).map((post) => toCardProps(post, lang));
---

<BaseLayout>
	<section class="hero">
		<h1>Seeking Sovngarde</h1>
		<p class="hero__lead">
			A journal on programming, tabletop RPGs and miniature painting.
		</p>
	</section>

	<SkyrimDivider label="Journal entries" />

	<section aria-label="Journal entries">
		<ul class="posts">
			{
				latest.map((post) => (
					<li>
						<PostCard {...post} />
					</li>
				))
			}
		</ul>
	</section>
</BaseLayout>

<style>
	.hero {
		text-align: center;
		max-width: 44rem;
		margin-inline: auto;
		padding-block: clamp(1rem, 5vw, 3rem);
	}

	.hero__lead {
		margin-top: 1rem;
		font-size: clamp(1rem, 2.5vw, 1.2rem);
		color: var(--muted);
	}

	.posts {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(min(100%, 20rem), 1fr));
		gap: clamp(1rem, 3vw, 1.75rem);
	}
</style>
